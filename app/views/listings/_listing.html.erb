<div class="col">
  <div class="card h-100 shadow-sm">
    <img src="<%= listing.photo_url %>" class="card-img-top" alt="<%= listing.title %>">
    <div class="card-body">
      <h5 class="card-title"><%= listing.title %></h5>
      <p class="card-text text-muted"><%= listing.city %></p>
      <p class="card-text fw-bold"><%= listing.price %>€ / nuit</p>
      <%= link_to "Voir l'annonce", listing, class: "btn btn-outline-danger btn-sm" %>
    </div>
  </div>
</div>

